<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #f5f5f5;"
      prefWidth="480" prefHeight="550">

    <!-- Header Band -->
    <VBox alignment="CENTER" style="-fx-background-color: #528deb;" prefHeight="140">
        <Label text="🔐" style="-fx-font-size: 40px; -fx-text-fill: #FFFFFF;"/>
        <Label text="Employee Management System"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-padding: 6 0 0 0;"/>
        <Label text="Login to Continue"
               style="-fx-font-size: 12px; -fx-text-fill: #cccccc; -fx-padding: 4 0 0 0;"/>
    </VBox>

    <!-- Login Card -->
    <VBox alignment="TOP_LEFT" spacing="16"
          style="-fx-background-color: #FFFFFF; -fx-border-color: #e0e0e0; -fx-border-width: 1;
                 -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 36 40 36 40;"
          maxWidth="360">

        <!-- Username Field -->
        <VBox spacing="4">
            <Label text="👤  Username" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <TextField fx:id="usernameField" promptText="Enter username"
                       style="-fx-font-size: 13px; -fx-background-color: #f5f5f5;
                              -fx-border-color: #cccccc; -fx-border-radius: 3; -fx-background-radius: 3;
                              -fx-padding: 9 12;"/>
        </VBox>

        <!-- Password Field -->
        <VBox spacing="4">
            <Label text="🔒  Password" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <PasswordField fx:id="passwordField" promptText="Enter password"
                           style="-fx-font-size: 13px; -fx-background-color: #f5f5f5;
                                  -fx-border-color: #cccccc; -fx-border-radius: 3; -fx-background-radius: 3;
                                  -fx-padding: 9 12;"/>
        </VBox>

        <!-- Error Label -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #333333; -fx-font-size: 12px; -fx-font-weight: bold;
                      -fx-background-color: #f0f0f0; -fx-border-color: #cccccc;
                      -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 6 10;"
               managed="false" visible="false" wrapText="true" maxWidth="280"/>

        <!-- Login Button -->
        <Button fx:id="loginButton" text="LOGIN" onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #528deb; -fx-text-fill: #FFFFFF;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-cursor: hand; -fx-padding: 12;
                       -fx-border-radius: 3; -fx-background-radius: 3;"/>
    </VBox>

    <VBox.margin>
        <Insets top="30"/>
    </VBox.margin>
</VBox>